{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/backnd-base-agent-kit/schemas/topic.schema.json",
  "title": "BACKND Agent Topic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "product",
    "route_family_id",
    "route_family",
    "source_routes",
    "summary",
    "capabilities",
    "prerequisites",
    "common_pitfalls",
    "related_topics",
    "keywords",
    "last_reviewed",
    "public_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "product": {
      "type": "string",
      "minLength": 1
    },
    "route_family_id": {
      "type": "string",
      "minLength": 1
    },
    "route_family": {
      "type": "string",
      "minLength": 1
    },
    "source_routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "common_pitfalls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "public_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
